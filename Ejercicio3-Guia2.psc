//Ingresa una letra: A ? Exelente, B ? Bueno, C ? Regular, D ? Deficiente, F ? Resprobado
Algoritmo Ejercicio3
	Definir letra Como Caracter
	Escribir Sin Saltar "Digite una letra: "
	leer letra
	
	Segun letra Hacer
		"A" o "a":
			Escribir "Exelente"
		"B" o "b":
			Escribir "Bueno"
		"C" o "c":
			Escribir "Regular"
		"D" o "d":
			Escribir "Deficiente"
		"F" o "f":
			Escribir "Resprobado"
		De Otro Modo:
			Escribir "Letra no válida!!!"
	Fin Segun
FinAlgoritmo
